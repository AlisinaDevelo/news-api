{
  "name": "news-api",
  "version": "1.0.0",
  "description": "REST API for news search using the GNews API",
  "main": "dist/server.js",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/server.js",
    "dev": "nodemon --exec ts-node src/server.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src test vitest.config.ts"
  },
  "keywords": [
    "news",
    "gnews",
    "express",
    "api"
  ],
  "license": "MIT",
  "dependencies": {
    "axios": "^1.7.6",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "node-cache": "^5.1.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.0",
    "@types/supertest": "^7.2.0",
    "@vitest/coverage-v8": "^4.1.2",
    "eslint": "^9.39.4",
    "nodemon": "^3.1.4",
    "supertest": "^7.2.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.5.4",
    "typescript-eslint": "^8.58.0",
    "vitest": "^4.1.2"
  }
}
