# Copy to .env. Never commit .env.

GNEWS_API_KEY=
PORT=3000

# Optional operations (see docs/OPERATIONS.md)
# NODE_ENV=production
# LOG_LEVEL=info
# HTTP_TIMEOUT_MS=15000
# SHUTDOWN_TIMEOUT_MS=10000
# RATE_LIMIT_MAX=120
# RATE_LIMIT_WINDOW_MS=60000
# TRUST_PROXY=0
# DISABLE_RATE_LIMIT=0
# REDIS_URL=redis://localhost:6379
# CLIENT_API_KEYS=client-secret-one,client-secret-two
# OpenTelemetry (omit to disable; set endpoint or OTEL_TRACING_ENABLED=1)
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
# OTEL_EXPORTER_OTLP_TRACES_ENDPOINT=http://localhost:4318/v1/traces
# OTEL_SERVICE_NAME=news-api
# OTEL_TRACING_ENABLED=0
